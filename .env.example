# dht-scan configuration. Copy to .env and edit.
# Real environment variables override these; CLI flags override env.

# Coordinator/API host to fetch the provider list from (/api/v1/providers/search).
# Point this at your test mytonprovider while prod is down.
DHTSCAN_HOST=https://mytonprovider.org

# How many providers to fetch and probe.
DHTSCAN_LIMIT=20

# uptime_gt_percent filter for the provider search.
DHTSCAN_UPTIME=50

# Probe these exact hex pubkeys instead of calling the API (comma-separated).
# Leave empty to use the API.
DHTSCAN_PUBKEYS=

# TON global config (must match the network your providers live on).
DHTSCAN_TON_CONFIG=https://ton-blockchain.github.io/global.config.json

# Local UDP port for ADNL/DHT. Use 0 for a random port if 16167 is taken
# by a storage/ADNL daemon already running on this host.
DHTSCAN_UDP_PORT=16167

# Parallel provider probes.
DHTSCAN_CONCURRENCY=8

# Per-provider timeout (Go duration: 10s, 1m, ...).
DHTSCAN_TIMEOUT=10s

# Also run the RLDP GetStorageRates step after DHT resolve (true/false).
DHTSCAN_RLDP=true
